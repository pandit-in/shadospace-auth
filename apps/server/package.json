{
  "name": "server",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:",
    "@shadospace-auth/auth": "workspace:*",
    "@shadospace-auth/db": "workspace:*",
    "hono": "catalog:",
    "@trpc/server": "catalog:",
    "@hono/trpc-server": "^0.4.0",
    "better-auth": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "tsdown": "^0.21.9",
    "@shadospace-auth/config": "workspace:*",
    "@types/bun": "catalog:"
  }
}