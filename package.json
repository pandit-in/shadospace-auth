{
  "name": "shadospace-auth",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "better-auth": "^1.6.8",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "hono": "^4.7.10",
      "@trpc/server": "^11.1.3",
      "@trpc/client": "^11.1.3",
      "@types/bun": "latest"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @shadospace-auth/db db:push",
    "db:studio": "turbo -F @shadospace-auth/db db:studio",
    "db:generate": "turbo -F @shadospace-auth/db db:generate",
    "db:migrate": "turbo -F @shadospace-auth/db db:migrate"
  },
  "packageManager": "bun@latest",
  "dependencies": {
    "better-auth": "^1.6.8",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "@types/node": "^22.13.14",
    "@shadospace-auth/config": "workspace:*",
    "turbo": "^2.8.12"
  }
}